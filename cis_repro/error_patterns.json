  "global_rules": [
    {
      "id": "GP-001",
      "name": "stop_decay_mismatch",
      "detect": "stop_when_dft_decayed 값이 원본과 다른 경우",
      "symptom": "FL이 길거나(>=2μm) 셀이 클 때 효율값 불안정/과소평가",
      "root_cause": "1e-6로 끊으면 FL=4μm 같은 긴 경로에서 field가 decay 완료 전 종료",
      "fix": "params.json의 stop_decay 값을 원본 notebook 값으로 사용",
      "verified_cases": [
        "RGBIR2025: 1e-8",
        "SMA2023: 1e-8",
        "Pixel2022: 1e-8",
        "SMA2023: FL=4.0μm → 1e-8 성공"
      ]
    },
    {
      "id": "GP-002",
      "name": "source_duplication",
      "detect": "mp.Source가 3개 이상인 경우 (Ex, Ey, Ex 중복)",
      "symptom": "소스 에너지 과잉 → 효율 > 1 또는 이상 수치",
      "root_cause": "참조 시뮬 source 교체 시 기존 source 배열에 추가되는 버그",
      "fix": "source 리스트를 Ex+Ey 정확히 2개로 고정",
      "verified_cases": [
        "SMA2023",
        "Simplest2023",
        "RGBIR2025"
      ]
    },
    {
      "id": "GP-003",
      "name": "ref_sim_geometry_wrong",
      "detect": "참조 시뮬(geometry_1)이 완전 Air 단일 블록인 경우",
      "symptom": "total_flux 기준이 달라져 효율 정규화 오차",
      "root_cause": "원본에 따라 참조 시뮬도 SiO2 cover를 포함해야 하는 경우 있음",
      "fix": "params.json의 ref_sim_type 참조: 'air'(Air 단일) vs 'with_cover'(SiO2 포함)",
      "verified_cases": [
        "Simplest2023: with_cover",
        "SMA2023: air",
        "RGBIR2025: air"
      ]
    }
  ],
