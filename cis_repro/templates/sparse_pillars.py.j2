"""
[Design Region: sparse_pillars]
소수의 사각기둥 meta-atom — 논문에서 직접 좌표/크기 명시

[암묵지]
- 각 pillar 크기와 위치가 직접 논문에 명시 (역설계 아님)
- 보통 4개 (Bayer 4분면 중심 각 1개)
- 파장별로 다른 크기 → 크기가 공진 파장 결정
- SMA 논문: R=920nm, G=160nm, B=280nm 사각기둥
"""

# ─── Sparse meta-atom 좌표 + 크기 ────────────────────────────────
# [암묵지] 각 사분면 중심에 위치: (±SP_size/2, ±SP_size/2)
_quadrant_centers = {
    'R':  (-SP_size/2, -SP_size/2),  # R 픽셀 위치
    'Gr': (-SP_size/2, +SP_size/2),  # Gr 픽셀 위치
    'B':  (+SP_size/2, +SP_size/2),  # B 픽셀 위치
    'Gb': (+SP_size/2, -SP_size/2),  # Gb 픽셀 위치
}

# 논문에서 명시된 pillar 파라미터
_pillars = {{ pillars }}
# 형식: [{'label': 'R', 'wx': 0.92, 'wy': 0.92, 'cx': -0.56, 'cy': 0.56}, ...]

for _p in _pillars:
    _cx = _p.get('cx', _quadrant_centers.get(_p['label'], (0,0))[0])
    _cy = _p.get('cy', _quadrant_centers.get(_p['label'], (0,0))[1])
    _wx = _p['wx']
    _wy = _p.get('wy', _wx)  # 정사각형이면 wy=wx

    # [암묵지] 경계 체크: pillar가 인접 사분면을 침범하지 않아야 함
    assert abs(_cx) + _wx/2 <= SP_size + 0.01, \
        f"pillar '{_p['label']}' X 경계 초과: cx={_cx}, wx={_wx}"
    assert abs(_cy) + _wy/2 <= SP_size + 0.01, \
        f"pillar '{_p['label']}' Y 경계 초과: cy={_cy}, wy={_wy}"

    geometry.append(mp.Block(
        size=mp.Vector3(_wx, _wy, Layer_thickness),
        center=mp.Vector3(round(_cx, 3), round(_cy, 3), z_meta),
        material={{ material_name }},
    ))

print(f"[Sparse] {len(_pillars)}개 meta-atom 추가")
for _p in _pillars:
    print(f"  {_p['label']}: {_p['wx']*1000:.0f}nm × {_p.get('wy',_p['wx'])*1000:.0f}nm")
